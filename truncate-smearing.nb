Notebook[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"gauss", "[", 
   RowBox[{"x_", ",", "R_"}], "]"}], ":=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{
     SqrtBox["\[Pi]"], " ", "R"}]], 
   RowBox[{"Exp", "[", 
    FractionBox[
     RowBox[{"-", 
      SuperscriptBox["x", "2"]}], 
     SuperscriptBox["R", "2"]], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"gaussTrunc", "[", 
   RowBox[{"x_", ",", "R_", ",", "cut_"}], "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"x", "<", 
        RowBox[{"-", "cut"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"gauss", "[", 
        RowBox[{"x", ",", "R"}], "]"}], ",", 
       RowBox[{
        RowBox[{"-", "cut"}], "<=", "x", "<=", "cut"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"x", ">", "cut"}]}], "}"}]}], "}"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"normCorr", "[", 
   RowBox[{"R_", ",", "cut_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"\[Lambda]", "=", 
      FractionBox["cut", "R"]}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       FractionBox["2", 
        SqrtBox["\[Pi]"]]}], "\[Lambda]", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"-", 
        SuperscriptBox["\[Lambda]", "2"]}], "]"}]}], "+", 
     RowBox[{"Erf", "[", "\[Lambda]", "]"}]}]}], "]"}]}]}], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"20f5697d-23c8-4f4c-bc88-d51616bb4938"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"gauss", "[", 
        RowBox[{"x", ",", "\[Sigma]"}], "]"}], ",", 
       FractionBox[
        RowBox[{"gaussTrunc", "[", 
         RowBox[{"x", ",", "\[Sigma]", ",", 
          RowBox[{"\[Sigma]", " ", "cutInSigma"}]}], "]"}], 
        RowBox[{"normCorr", "[", 
         RowBox[{"\[Sigma]", ",", " ", 
          RowBox[{"\[Sigma]", " ", "cutInSigma"}]}], "]"}]]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1.5"}], "}"}]}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Sigma]", ",", "0.2", ",", "2", ",", "0.1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"cutInSigma", ",", "1", ",", "10", ",", "0.1"}], "}"}]}], 
  "]"}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"d2fb0eeb-d3e6-415d-84d0-052e356d2a88"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"gaussTrunc", "[", 
       RowBox[{"x", ",", "\[Sigma]", ",", 
        RowBox[{"cutInSigma", " ", "\[Sigma]"}]}], "]"}], 
      RowBox[{"normCorr", "[", 
       RowBox[{"\[Sigma]", ",", 
        RowBox[{"cutInSigma", " ", "\[Sigma]"}]}], "]"}]], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "10"}], ",", "10"}], "}"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"\[Sigma]", ",", "0.5", ",", "10"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"cutInSigma", ",", "1", ",", "10"}], "}"}]}], "]"}]], "Input",
 CellLabel->"In[86]:=",ExpressionUUID->"69f7428b-0da4-4b53-83bd-ecc0306f873b"],

Cell[BoxData[""], "Input",ExpressionUUID->"7ff95e6b-5a58-40f3-8919-5f8c67e1ac74"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Kernel", "[", 
    RowBox[{"x_", ",", "\[Beta]_", ",", "R_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Gamma]x\[Beta]", "=", 
       FractionBox[
        RowBox[{"Total", "[", 
         RowBox[{"x", "*", "\[Beta]"}], "]"}], 
        SqrtBox[
         RowBox[{"1", "-", 
          RowBox[{"Total", "[", 
           SuperscriptBox["\[Beta]", "2"], "]"}]}]]]}], "}"}], ",", 
     RowBox[{"Exp", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"-", 
         RowBox[{"Total", "[", 
          SuperscriptBox["x", "2"], "]"}]}], "-", 
        SuperscriptBox["\[Gamma]x\[Beta]", "2"]}], 
       SuperscriptBox["R", "2"]], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Kernel2", "[", 
   RowBox[{"x_", ",", "\[Beta]_", ",", "R_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x\[Beta]", "=", 
      RowBox[{"Total", "[", 
       RowBox[{"x", "*", "\[Beta]"}], "]"}]}], "}"}], ",", 
    RowBox[{"Exp", "[", 
     FractionBox[
      RowBox[{
       RowBox[{"-", 
        RowBox[{"Total", "[", 
         SuperscriptBox["x", "2"], "]"}]}], "-", 
       SuperscriptBox["x\[Beta]", "2"]}], 
      SuperscriptBox["R", "2"]], "]"}]}], "]"}]}]}], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"9176629e-9a15-4e99-b5f7-f3233815dd5e"],

