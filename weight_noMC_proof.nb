Notebook[{

Cell[CellGroupData[{
Cell["\<\
Proof that Monte - Carlo sampling isn' t needed for dilepton emission\
\>", "Section",
 InitializationCell->
  True,ExpressionUUID->"eafbc0f0-62f9-4a8d-846b-cf066cbb2b69"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"nBin", "=", "30"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"nIter", "=", 
   SuperscriptBox["10", "5"]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"add", "=", "0.01"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pdfGamma", "[", "x_", "]"}], ":=", 
  RowBox[{"PDF", "[", 
   RowBox[{
    RowBox[{"GammaDistribution", "[", 
     RowBox[{"4", ",", "1"}], "]"}], ",", "x"}], "]"}]}]}], "Code",
 CellLabel->
  "In[209]:=",ExpressionUUID->"01f46220-0ec6-4a50-9c88-843bd6e64cd7"],

Cell["+0.01 added for visibility\[AliasDelimiter]", "Text",ExpressionUUID->"5961ccb1-a7ee-410b-b519-151e9e69f7ae"],

Cell[CellGroupData[{

Cell[TextData[{
 "If I\[CloseCurlyQuote]m producing dileptons perturbatively (no dynamics \
associated with them), I can simply oversample ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    SubscriptBox["m", "ee"]}], TraditionalForm]],ExpressionUUID->
  "9ba8fe05-b1b6-4843-a4cd-40d0f0baf697"],
 ", ",
 Cell[BoxData[
  FormBox[
   OverscriptBox["q", "\[RightVector]"], TraditionalForm]],ExpressionUUID->
  "d190dee4-06bb-4093-8b17-efefc04366f8"],
 ") from a uniform 4D distribution in a large enough range, and weight each \
dilepton with the value of the distribution function."
}], "Subsubsection",ExpressionUUID->"56118559-87dc-4386-a6f9-8046af6977d6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"unif", "=", 
   RowBox[{"RandomReal", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "20"}], "}"}], ",", "nIter"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"weight", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"pdfGamma", "[", "#", "]"}], "&"}], "/@", "unif"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dit", "=", 
   RowBox[{"HistogramDistribution", "[", 
    RowBox[{
     RowBox[{"WeightedData", "[", 
      RowBox[{"unif", ",", "weight"}], "]"}], ",", "nBin"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Histogram", "[", 
     RowBox[{
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"GammaDistribution", "[", 
         RowBox[{"4", ",", "1"}], "]"}], ",", "nIter"}], "]"}], ",", "nBin", 
      ",", "\"\<PDF\>\"", ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "10"}], "}"}], ",", "All"}], "}"}]}]}], "]"}], 
    ",", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"pdfGamma", "[", "y", "]"}], ",", 
        RowBox[{
         RowBox[{"pdfGamma", "[", "y", "]"}], "+", "add"}], ",", 
        RowBox[{
         RowBox[{"PDF", "[", 
          RowBox[{"dit", ",", "y"}], "]"}], "+", "add"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", "10"}], "}"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "10"}], "}"}], ",", "All"}], "}"}]}]}], "]"}]}], 
   "}"}], "]"}]}], "Input",
 CellLabel->
  "In[170]:=",ExpressionUUID->"63bd85ac-9301-4bd7-9956-309dea850313"],

