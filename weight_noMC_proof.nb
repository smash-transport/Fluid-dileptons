Cell[CellGroupData[{

Cell["\<\
The beta distribution is defined in the interval [0,1], so it does not have \
the support we need.\
\>", "Subsubsection",
 CellFrame->{{0, 0}, {0, 3}},
 CellFrameColor->GrayLevel[
  0.75],ExpressionUUID->"69e9fad4-a0f4-47a5-a529-a94e806218ae"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"beta", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"BetaDistribution", "[", 
      RowBox[{"2", ",", "2"}], "]"}], ",", "nIter"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pdfBeta", "[", "x_", "]"}], ":=", " ", 
  RowBox[{"PDF", "[", 
   RowBox[{
    RowBox[{"BetaDistribution", "[", 
     RowBox[{"2", ",", "2"}], "]"}], ",", "x"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"weight", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"pdfGamma", "[", "#", "]"}], "/", 
      RowBox[{"pdfBeta", "[", "#", "]"}]}], "&"}], "/@", "beta"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dit", "=", 
   RowBox[{"HistogramDistribution", "[", 
    RowBox[{
     RowBox[{"WeightedData", "[", 
      RowBox[{"beta", ",", "weight"}], "]"}], ",", "nBin"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Histogram", "[", 
     RowBox[{
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"GammaDistribution", "[", 
         RowBox[{"4", ",", "1"}], "]"}], ",", "nIter"}], "]"}], ",", "nBin", 
      ",", "\"\<PDF\>\"", ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "10"}], "}"}], ",", "All"}], "}"}]}]}], "]"}], 
    ",", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"pdfGamma", "[", "y", "]"}], ",", 
        RowBox[{
         RowBox[{"pdfGamma", "[", "y", "]"}], "+", "add"}], ",", 
        RowBox[{
         RowBox[{"PDF", "[", 
          RowBox[{"dit", ",", "y"}], "]"}], "+", "add"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", "10"}], "}"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "10"}], "}"}], ",", "All"}], "}"}]}]}], "]"}]}], 
   "}"}], "]"}]}], "Input",
 CellLabel->
  "In[179]:=",ExpressionUUID->"65c085f6-a654-4d8e-819a-4ee9fbddd706"],

