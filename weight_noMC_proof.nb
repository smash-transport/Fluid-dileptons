Cell["\<\
Actually, we can sample from any arbitrary distribution that has the \
necessary support, by dividing the weight with the corresponding pdf.\
\>", "Subsubsection",
 CellFrame->{{0, 0}, {0, 3}},
 CellFrameColor->GrayLevel[
  0.75],ExpressionUUID->"fc7550e7-8c0b-4613-a8d6-91039b4c0f47"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"triang", "=", 
   RowBox[{"RandomVariate", "[", 
    RowBox[{
     RowBox[{"TriangularDistribution", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "20"}], "}"}], ",", "0"}], "]"}], ",", "nIter"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pdfTriang", "[", "x_", "]"}], ":=", " ", 
  RowBox[{"PDF", "[", 
   RowBox[{
    RowBox[{"TriangularDistribution", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "20"}], "}"}], ",", "0"}], "]"}], ",", "x"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"weight", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"pdfGamma", "[", "#", "]"}], "/", 
      RowBox[{"pdfTriang", "[", "#", "]"}]}], "&"}], "/@", "triang"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dit", "=", 
   RowBox[{"HistogramDistribution", "[", 
    RowBox[{
     RowBox[{"WeightedData", "[", 
      RowBox[{"triang", ",", "weight"}], "]"}], ",", "nBin"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"Histogram", "[", 
     RowBox[{
      RowBox[{"RandomVariate", "[", 
       RowBox[{
        RowBox[{"GammaDistribution", "[", 
         RowBox[{"4", ",", "1"}], "]"}], ",", "nIter"}], "]"}], ",", "nBin", 
      ",", "\"\<PDF\>\"", ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "10"}], "}"}], ",", "All"}], "}"}]}]}], "]"}], 
    ",", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"pdfGamma", "[", "y", "]"}], ",", 
        RowBox[{
         RowBox[{"pdfGamma", "[", "y", "]"}], "+", "add"}], ",", 
        RowBox[{
         RowBox[{"PDF", "[", 
          RowBox[{"dit", ",", "y"}], "]"}], "+", "add"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "0", ",", "13"}], "}"}], ",", 
      RowBox[{"PlotRange", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "10"}], "}"}], ",", "All"}], "}"}]}]}], "]"}]}], 
   "}"}], "]"}]}], "Input",
 CellLabel->
  "In[213]:=",ExpressionUUID->"bb79418d-595c-46d4-acd6-4d1fb3b94d21"],

